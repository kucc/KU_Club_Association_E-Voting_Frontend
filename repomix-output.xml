              className="h-[44px] flex-[2.5] rounded-[10px] bg-[#A0191E] font-semibold text-[#FFFFFF] disabled:opacity-30"
            >
              {isUpdatePending ? '수정 중...' : '수정 완료'}
            </button>
          </div>
        </div>
      </div>
    </main>
  );
}
